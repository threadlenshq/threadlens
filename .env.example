# Scout Open-Core runtime env
# Copy this file to .env in the open-core/ directory.
# The Docker scripts will auto-create open-core/.env from this file on first run.

# AI providers (set at least one if you want AI-powered analysis)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Google search provider (required for Google scouting)
PARALLEL_API_KEY=

# Bluesky scouting (required only for Bluesky features)
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# Optional app flags
# SCOUT_INIT_DEMO=1

# ── Host CLI bridge (pnpm run docker:dev bootstrap) ───────────────────────────
# The bridge daemon lets the containerised Go API call AI tools installed on the
# host (e.g. claude, copilot).  All variables are optional; defaults work for
# most local setups.

# URL the container uses to reach the bridge (default: http://host.docker.internal:4750)
# SCOUT_AI_BRIDGE_URL=http://host.docker.internal:4750

# Shared-secret token for bridge auth (auto-generated on first run if omitted)
# SCOUT_AI_BRIDGE_TOKEN=

# Path inside the container where the bridge token is written/read
# SCOUT_AI_BRIDGE_TOKEN_FILE=/run/secrets/bridge_token

# Path on the HOST where the bridge token is persisted across restarts
# SCOUT_AI_BRIDGE_HOST_TOKEN_FILE=~/.scout/bridge_token

# Address the bridge daemon listens on (default: 127.0.0.1:4750)
# SCOUT_AI_BRIDGE_BIND=127.0.0.1:4750

# Set to 1 to disable the bridge entirely and fall back to direct SDK calls
# SCOUT_AI_BRIDGE_DISABLE=

# Set to 1 to skip auto-launching the bridge daemon (useful if you start it manually)
# SCOUT_BRIDGE_NO_LAUNCH=
