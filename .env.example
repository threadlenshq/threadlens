# Scout Open-Core runtime env
# Copy this file to .env in the open-core/ directory.
# The Docker scripts will auto-create open-core/.env from this file on first run.

# AI providers (set at least one if you want AI-powered analysis)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Google search provider (required for Google scouting)
PARALLEL_API_KEY=

# Bluesky scouting (required only for Bluesky features)
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# Optional app flags
# SCOUT_INIT_DEMO=1

# ── Optional local host CLI bridge for Docker development ─────────────────────
# Production and VPS self-host deployments do not need the bridge. For reliable
# production AI, set ANTHROPIC_API_KEY or GEMINI_API_KEY, or install and
# authenticate Copilot CLI or Claude CLI inside the API runtime environment.
# `pnpm run docker:dev` may populate the bridge variables below as a best-effort
# local convenience for reusing host-authenticated CLI sessions.

# Enable local bridge config-file discovery. Leave empty for production.
# SCOUT_AI_BRIDGE_MODE=local

# Docker-facing bridge URL generated by local dev bootstrap.
# SCOUT_AI_BRIDGE_URL=http://host.docker.internal:4761

# Path inside the container where Docker dev mounts the bridge bearer token.
# SCOUT_AI_BRIDGE_TOKEN_FILE=/run/secrets/scout-ai-bridge-token

# Host token path used only by the Docker dev Compose bind mount.
# SCOUT_AI_BRIDGE_HOST_TOKEN_FILE=~/.config/scout/ai-bridge.token

# Address the local bridge daemon listens on when launched for development.
# SCOUT_AI_BRIDGE_BIND=127.0.0.1:4761

# Set to 1 to disable bridge discovery, health checks, and generation calls.
# SCOUT_AI_BRIDGE_DISABLE=

# Set to 1 to skip auto-launching the local bridge daemon during docker:dev.
# SCOUT_BRIDGE_NO_LAUNCH=

# ── Onboarding / first-run experience ────────────────────────────────────────
# Controls the guided onboarding flow shown to new users.

# Deployment context for onboarding. Set to "docker" in Docker/container
# environments so that the onboarding config is persisted to /data/.env.
# Leave unset (or set to "local") for non-containerised installs.
# SCOUT_ONBOARDING_MODE=docker

# Set to 1 to skip the onboarding wizard entirely (useful for automated or
# pre-configured deployments where env vars are already supplied).
# SCOUT_ONBOARDING_DISABLE=

# ── Anonymous telemetry ──────────────────────────────────────────────────────
# Set to 1 to enable anonymous usage telemetry. Telemetry is off by default.
# When enabled, the onboarding wizard and Settings → Privacy page let the
# user opt in or out of sending events. No personal data is ever collected.
# See https://docs.threadlens.dev/reference/telemetry/ for details.
# SCOUT_TELEMETRY_OPT_IN=1
