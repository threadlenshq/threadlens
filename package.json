{
  "name": "scout-open-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:go": "cd apps/api && go build ./...",
    "test": "turbo run test",
    "test:go": "cd apps/api && go test ./...",
    "docker:dev": "docker compose -f infra/docker/compose.yml --profile dev up --build -d",
    "docker:prod": "docker compose -f infra/docker/compose.yml --profile prod up --build -d",
    "docker:down": "docker compose -f infra/docker/compose.yml --profile dev down && docker compose -f infra/docker/compose.yml --profile prod down"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
